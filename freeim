pad_right() {
    local colored width plain pad
    colored="$1"
    width=18
    plain=$(echo "${colored}" | sed 's/\x1b\[[0-9;]*m//g' | xargs)
    pad=$((width - ${#plain}))
    printf '%*s%s' "${pad}" '' "${colored}"
    return 0
}
