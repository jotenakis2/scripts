display_swap_comp() { # zram ou zswap
    local back="$1" comp_algo="$2" pool_max="$3" pool_used="$4" data="$5"
    local explain_pool="$6" explain_used="$7" explain_data="$8"
    local dev temp c1 c2 c3 c4 c5 c6 c7 d1 d2 d3 d4 d5 d6 d7

    # gestion multi swap
    for dev in ${swap_devices}; do
        temp=$(pad_right "${C_BLUE}${dev}${Reset}")
        printf " PÃĐriphÃĐrique     : %s %s\n" "${temp}" "${explain_device}"
    done

    # construction
    c1="${C_BLUE}${back}(${comp_algo})${Reset}"
    d1=$(pad_right "${c1}")
    c2=$(format_size "${swapcached}")
    d2=$(pad_right "${c2}")
    c3=$(format_size "${pool_max}")
    d3=$(pad_right "${c3}")
    c4=$(format_size "${pool_used}")
    d4=$(pad_right "${c4}")
    # affichage
    printf " Compression      : %s   %s\n" "${d1}" "${explain_comp}"
    printf " Swap en cache    : %s   %s\n" "${d2}" "${explain_cached}"
    printf " Pool ${back} max   : %s   %s\n" "${d3}" "${explain_pool}"
    printf " Pool ${back}       : %s   %s\n" "${d4}" "${explain_used}"

    # gestion ratio de compression
    if ((data > 0)); then
        c5=$(format_size "${data}")
        d5=$(pad_right "${c5}")
        printf " DonnÃĐes ${back}    : %s   %s\n" "${d5}" "${explain_data}"
        if ((pool_used > 0)); then
            local ratio
            d6=$(echo "scale=1; ${data} / ${pool_used}" | bc)
            ratio=$(printf "%.1f" "${d6}")
            c7="${C_BLUE}x${ratio}${Reset}"
            d7=$(pad_right "${c7}")
            printf " EfficacitÃĐ       : %s   %s\n" "${d7}" "${explain_ratio}"
        fi
    fi
    return 0
}
