display_as_free() {
    local pad=12 c1 c2 c3 c4 c5 c6 d1 d2 d3 d4 d5 d6 bufcache

	pad_col() {
	    local colored="$1" stripped len spaces
	    stripped=$(printf '%s' "${colored}" | sed -E 's/\x1b\[[0-9;]*m//g; s/\x1b\(B//g')
	    len=${#stripped}
	    spaces=$((pad - len))
	    printf '%*s%s' "${spaces}" '' "${colored}"
	}

    # header
    c1=$(pad_col "total")
    c2=$(pad_col "utilisÃĐ")
    c3=$(pad_col "libre")
    c4=$(pad_col "partagÃĐ")
    c5=$(pad_col "tamp/cache")
    c6=$(pad_col "disponible")
    printf "%-6s%s%s%s%s%s%s\n" "" "${c1}" "${c2}" "${c3}" "${c4}" "${c5}" "${c6}"

    # Mem
    bufcache=$((buffers + cached + sreclaimable)) # la commande free calcule buff/cache = Buffers + Cached + SReclaimable
    c1=$(format_size "${mem_total}")
    d1=$(pad_col "${c1}")
    c2=$(format_size "${mem_used}")
    d2=$(pad_col "${c2}")
    c3=$(format_size "${mem_free}")
    d3=$(pad_col "${c3}")
    c4=$(format_size "${shmem}")
    d4=$(pad_col "${c4}")
    c5=$(format_size "${bufcache}")
    d5=$(pad_col "${c5}")
    c6=$(format_size "${mem_avail}")
    d6=$(pad_col "${c6}")
    printf "%-6s%s%s%s%s%s%s\n" "Mem :" "${d1}" "${d2}" "${d3}" "${d4}" "${d5}" "${d6}"

    # Swap
    c1=$(format_size "${swap_total}")
    d1=$(pad_col "${c1}")
    c2=$(format_size "${swap_used}")
    d2=$(pad_col "${c2}")
    c3=$(format_size "${swap_free}")
    d3=$(pad_col "${c3}")
    [[ "${c1}" == "0" ]] && printf "%-6s%s%s%s\n" "Swap:" "${d1}" "${d2}" "${d3}"
    exit 0
}
