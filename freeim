    d2=$(pad_right "${c2}")
    c3="$(format_size "${swap_free}")"
    d3=$(pad_right "${c3}")
    # affichage
    printf "%s: %s\n" "${pad1}" "${d1}"
    printf "%s: %s   ${C_BLUE}%-4s%%${Reset}\n" "${pad2}" "${d2}" "${swap_used_pct}"
    printf "%s: %s   ${C_BLUE}%-4s%%${Reset}\n" "${pad3}" "${d3}" "${swap_free_pct}"
    [[ ${SIMPLE} == false ]] && display_SWAP_extended
    return 0
}
