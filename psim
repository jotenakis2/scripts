#####################################################################################################################################
#####################################################################################################################################
CLEANUP() {
    local END_TIME
    printf '\033[?25h\033[?1049l\033[H\033[2J'
    LOG
    STATS
    END_TIME=${SECONDS}
    echo -e "${Jaune}Fichier de log ${Reset}: ${Bleu}${LOGFILE}${Reset}"
    echo -e "\n󱠢  Au revoir... (${Jaune}${NAME}${Reset} v${Bleu}${VER}${Reset} a fonctionné pendant ${Bleu}$((END_TIME - START_TIME))${Reset}s)"
    exit 0
}
#####################################################################################################################################
ERROR() {
    local END_TIME
    printf '\033[?25h\033[?1049l\033[H\033[2J'
    echo -e "\n${RougeBold}  Terminal trop petit, affichage correct impossible\n"
    END_TIME=${SECONDS}
    echo -e "=> Arrêt forcé.${Reset}(${Jaune}${NAME}${Reset} v${Bleu}${VER}${Reset} a fonctionné pendant ${Bleu}$((END_TIME - START_TIME))${Reset}s)${Reset}"
    LOG
    exit 1
}
#####################################################################################################################################
EXISTS() {
    command -v "$1" >/dev/null 2>&1
}
#####################################################################################################################################
#shellcheck disable=SC2310
INITIALCONF() { # définition des variables globales principales
    if EXISTS ps && EXISTS awk ; then
        PS=$(command -v ps 2>/dev/null)
        AWK=$(command -v awk 2>/dev/null)
        DIRCACHE="${HOME}/.cache/psim"
	    mkdir -p "${DIRCACHE}"
        SORT="-%cpu"
        LIMIT=0
        NEWBIE=1
        INTERVAL=1
        NO_HEADER=0
        KERNEL=0
        NO_COLOR=0
        OFFSET=0
        TOTAL_PROCS=0
        FREEZE=0
        STATIC=0
        FILTER=""
        NCPU=$(nproc)
        ME=$(whoami)
        FORCE_HEADER=0
        DRAWN_FILE="${DIRCACHE}/drawn"
        : > "${DRAWN_FILE}"


        # TIPS_STATE : 0 = ni tips ni footer / 1 = tips + footer / 2 = tips sans footer
        TIPS_STATE=1

        # en mode noob par défaut on ne montre pas la colonne OPTIONS et le chemin des PROGRAM
        [[ ${NEWBIE} -eq 1 ]] && SHOW_OPTS=0 || SHOW_OPTS=1

        SEUILFREEZE=3599
        PSNOOB="pid,user:8,rss,%cpu,cmd"                  # format ps -o 'newbie'
        PSSIMPLE="pid,ppid,user:8,nice,rss,%mem,%cpu,cmd" # format ps -o 'normal'

        readonly PSNOOB PSSIMPLE PS AWK SEUILFREEZE ME NCPU

        # Chargement d'un éventuel fichier de conf qui écrase les valeurs initiales hardcodées
        mkdir -p "${DIR}"
        if [[ -f "${CONFIG}" ]]; then
            # shellcheck source=/dev/null
            source "${CONFIG}"
        fi

        # j'initialise les 2 scripts awk dans des variables globales en lecture seule.
        _awk
        return 0
    else # pb de dépendances
        echo ""
        EXISTS ps  || echo -e "\033[31mLa commande ps est manquante...\033[0m"
        EXISTS awk || echo -e "\033[31mLa commande awk est manquante...\033[0m"
        echo -e "\n 󱠢  Au revoir..."
        exit 1
    fi
}
#####################################################################################################################################
# shellcheck disable=SC2249
APPLY_TIPS_STATE() {
    case "${TIPS_STATE}" in
        0) NO_FOOTER=1 ;;
        1) NO_FOOTER=0 ;;
        2) NO_FOOTER=1 ;;
    esac
}
#####################################################################################################################################
LOG() { # on stocke les valeurs utilisées
    local heure date format versionps versionawk
    LOGDIR="${DIRCACHE}"
    LOGFILE="${LOGDIR}/log"
    [[ -e "${LOGFILE}" ]] || touch "${LOGFILE}"

    [[ ${NEWBIE} -eq 1 ]] && format="${PSNOOB}" || format="${PSSIMPLE}"
    heure="$(date '+%T')"
    date="$(date '+%A %d %B %Y')"
    versionps=$("${PS}" --version)
    versionawk=$("${AWK}" --version | head -1)

    {   echo "Nom         : ${NAME}"
        echo "Date        : ${heure}, le ${date}"
        echo "Version     : ${VER}"
        echo "USER        : ${ME}"
        echo "ncpu        : ${NCPU}"
        echo "PS          : ${PS} (${versionps})"
        echo "AWK         : ${AWK} (${versionawk})"
        echo "Tri         : ${SORT}"
        echo "Mode Newbie : ${NEWBIE}"
        echo "Format ps   : ${format}"
        echo "Refresh     : ${INTERVAL}"
        echo "NO header   : ${NO_HEADER}"
        echo "TIPS        : ${TIPS_STATE}"
        echo "Kernel mode : ${KERNEL}"
        echo "NO color    : ${NO_COLOR}"
        echo "Static      : ${STATIC}"
        echo "show opts   : ${SHOW_OPTS}"
        echo "Filtre      : ${FILTER}"
        echo "Terminal    : ${TERM}"
        echo "Colonnes    : ${COLUMNS}"
        echo "Lignes      : ${LINES}"
        echo "---------------------------------------------------------------------------"
        echo ""
    } >> "${LOGFILE}"

    return 0
}
#####################################################################################################################################
COUNT_PROCS(){ # calcule le nb total de processus en excluant ps lui-même
    local debug="${DIRCACHE}/debug" maxps
    maxps="${WIDTH}"
    if [[ -n "${FILTER}" ]]; then
        "${PS}" --no-headers --deselect --pid 2 --ppid 2 --deselect --pid "${MYPID}" --ppid "${MYPID}" \
        -o user=,cmd= --cols="${maxps}" 2>/dev/null | grep -Ei "${FILTER}" > "${debug}"
    else
        case "${KERNEL}" in
            0)  # USERLAND only
                "${PS}" --no-headers --deselect --pid 2 --ppid 2 --deselect --pid "${MYPID}" --ppid "${MYPID}" 2>/dev/null > "${debug}"
                ;;

            1)  # KERNEL + USERLAND
                "${PS}" --no-headers --deselect --pid "${MYPID}" --ppid "${MYPID}" 2>/dev/null > "${debug}"
                ;;

            2)  # KERNEL only
                "${PS}" --no-headers --pid 2 --ppid 2  2>/dev/null > "${debug}"
                ;;

            *) ;;
        esac
    fi
    TOTAL_PROCS=$(wc -l < "${debug}")
    rm -f "${debug}"
    return 0
}
#####################################################################################################################################
DISPLAY-TIPS(){ # Barre d'aide
    local scroll_info="" seuilsimple=160
    local cc cm cp cu ck ch cf CF cC co cP
    local int base_plain base_color filterstr="" available intcolor

    [[ ${OFFSET} -gt 0 ]] && scroll_info=" [+${OFFSET}]"

    cc="${BleuBold}" ; cm="${BleuBold}" ; cp="${BleuBold}" ; cu="${BleuBold}" ; cC="${BleuBold}"
    ck="${BleuBold}" ; ch="${BleuBold}" ; cf="${BleuBold}" ; CF="${BleuBold}" ; co="${BleuBold}" ; cP="${BleuBold}"

    case "${SORT}" in
        -%cpu|%cpu) cc="${Vert}" ;;
        -rss|rss) cm="${Vert}" ;;
        -pid|pid) cp="${Vert}" ;;
        -ppid|ppid) cP="${Vert}" ;;
        -user|user) cu="${Vert}" ;;
        -cmd|cmd) cC="${Vert}" ;;
        *) ;;
    esac

    [[ ${KERNEL} -ne 0 ]] && ck="${Vert}"
    [[ ${NO_HEADER} -eq 0 ]] && ch="${Vert}"
    [[ ${TIPS_STATE} -ge 1 ]] && cf="${Vert}"
    [[ ${FREEZE} -ge 1 ]] && CF="${Vert}"
    [[ ${SHOW_OPTS} -eq 1 ]] && co="${Vert}"

    intcolor="${Vert}${INTERVAL}${Gris}s"
    int="${INTERVAL}s"

    if [[ ${WIDTH} -lt ${seuilsimple} ]]; then
        [[ ${INTERVAL} -ge ${SEUILFREEZE} ]] && { intcolor="${Vert}F${Gris}"; int="F"; }
        base_plain="  [c]pu [m]em [p]id [P]pid [u]ser [C]md [o] [k] [h] [f] [ ] [q]uit [+/-] [F]   ${int}${scroll_info}"
        base_color="   ${cc}[c]${ResetFg}pu ${cm}[m]${ResetFg}em ${cp}[p]${ResetFg}id ${cP}[P]${ResetFg}pid ${cu}[u]${ResetFg}ser ${cC}[C]${ResetFg}md ${co}[o]${ResetFg} ${ck}[k]${ResetFg} ${ch}[h]${ResetFg} ${cf}[f]${ResetFg} ${BleuBold}[ ] [q]${ResetFg}uit ${BleuBold}[+/-]${ResetFg} ${CF}[F]${ResetFg}   ${intcolor}${scroll_info}${ResetFg}"
    else
        [[ ${INTERVAL} -ge ${SEUILFREEZE} ]] && { intcolor="${Vert}FREEZE${Gris}"; int="FREEZE"; }
        base_plain="  [c]pu | [m]em | [p]id | [P]pid | [u]ser | [C]md | [o]ptions | [k]ernel | [h]eader | [f]ooter | [ ]mode | [↓↑]scroll | [q]uit | [+/-]refresh | [F]reeze   ${int}${scroll_info}"
        base_color="   ${cc}[c]${ResetFg}pu | ${cm}[m]${ResetFg}em | ${cp}[p]${ResetFg}id | ${cP}[P]${ResetFg}pid | ${cu}[u]${ResetFg}ser | ${cC}[C]${ResetFg}md | ${co}[o]${ResetFg}ptions | ${ck}[k]${ResetFg}ernel | ${ch}[h]${ResetFg}eader | ${cf}[f]${ResetFg}ooter | ${BleuBold}[ ]${ResetFg}mode | ${BleuBold}[↓↑]${ResetFg}scroll | ${BleuBold}[q]${ResetFg}uit | ${BleuBold}[+/-]${ResetFg}refresh | ${CF}[F]${ResetFg}reeze   ${intcolor}${scroll_info}${ResetFg}"
    fi

    # on calcule la place restante pour afficher le FILTRE en croppant le moins possible
    if [[ -n "${FILTER}" ]]; then
        available=$(( WIDTH - ${#base_plain} - 6 ))
        [[ ${available} -lt 0 ]] && available=0
        if [[ ${#FILTER} -gt ${available} && ${available} -ge 2 ]]; then
            filterstr=" ${Jaune}${FILTER:0:$((available - 1))}${Gris}>>${ResetFg}"
        else
            filterstr=" ${Jaune}${FILTER:0:available}${ResetFg}"
        fi
    fi

    printf "%s%s%s\033[K%s" "${BgGrisFonce}" "${base_color}" "${filterstr}" "${Reset}"
    return 0
}


