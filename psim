# SCRIPTS AWK #######################################################################################################################
#####################################################################################################################################
#####################################################################################################################################
_psawk(){ # construction de la ligne de commande ps xxx | awk yyy
    local formatps awkscript maxps pscmd awkcmd noItSelf noKernel
    formatps="$1"
    maxps=$((WIDTH + 5))
    noItSelf=(--deselect --pid "${MYPID}" --ppid "${MYPID}")

    [[ ${NEWBIE} -eq 1 ]] && awkscript="${AWKNOOB}"                 || awkscript="${AWKSIMPLE}"
    [[ ${KERNEL} -eq 0 ]] && noKernel=(--deselect --pid 2 --ppid 2) || noKernel=()

    pscmd=("${PS}" -o "${formatps}" --sort="${SORT}" --cols="${maxps}")
    awkcmd=("${AWK}" \
            -v limit="${LIMIT}"        -v width="${WIDTH}"           -v ncpu="${NCPU}"          -v sort="${SORT}" \
            -v noheader="${NO_HEADER}" -v nofooter="${NO_FOOTER}"    -v kernel="${KERNEL}"      -v nocolor="${NO_COLOR}" \
            -v offset="${OFFSET}"      -v totalproc="${TOTAL_PROCS}" -v showopts="${SHOW_OPTS}" -v me="${ME}" \
            -v filter="${FILTER}"      -v drawn_file="${DRAWN_FILE}" "${awkscript}")

    "${pscmd[@]}" "${noKernel[@]}" "${noItSelf[@]}" 2>/dev/null | "${awkcmd[@]}" 2>/dev/null

    return 0
}
