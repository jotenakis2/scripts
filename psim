_awk(){ # initialisation des scripts awk dans des variables globales AWKSIMPLE et AWKNOOB

# script mode simple => variable globale
AWKSIMPLE=$(cat <<'EOF'
# DÉFINITION des codes ansi (couleurs,...)
    BEGIN{
       if(nocolor){
            RED=""
            GREEN=""
            YELLOW=""
            BLUE=""
            MAGENTA=""
            CYAN=""
            WHITE=""
            GREY=""
            BG_GREY=""
            RESET=""
            RESET_FG=""
            RESET_BG=""
            RESET_UL=""
            UNDERLINE=""
            EL="\033[0K"
       } else {
            RED="\033[31m"
            GREEN="\033[32m"
            YELLOW="\033[33m"
            BLUE="\033[34m"
            MAGENTA="\033[35m"
            CYAN="\033[36m"
            WHITE="\033[37m"
            GREY="\033[37m"
            BG_GREY="\033[100m"
            RESET_FG="\033[39m"
            RESET_BG="\033[49m"
            RESET="\033[0m"
            RESET_UL="\033[24m"
            UNDERLINE="\033[4m"
            EL="\033[0K"
       }
   }
# HEADER
   NR==1{
        if (noheader) next
        # couleurs et noms des catégories du header en fonction du tri choisi
          pid_start = (sort ~ /^-?pid$/) ? UNDERLINE MAGENTA : MAGENTA
          ppid_start = (sort ~ /^-?ppid$/) ? UNDERLINE CYAN : CYAN
          mib_start = (sort ~ /^-?rss$/) ? UNDERLINE GREEN : GREEN
          cpu_start = (sort ~ /^-?%?cpu$/) ? UNDERLINE GREEN : GREEN
          user_start = (sort ~ /^-?%?user$/) ? UNDERLINE BLUE : BLUE
          prog_col = "  COMMAND"
          if(showopts == 1) prog_col = "  CMD"
          opts_col = ""
          pcolor = (sort ~ /^-?%?cmd$/) ? UNDERLINE YELLOW : YELLOW

        # Affichage header
          printf BG_GREY pid_start "%7s" RESET_UL " " ppid_start "%7s" RESET_UL " " user_start "%-10s" RESET_UL WHITE " %3s " mib_start "%6s" RESET_UL " " GREEN "%6s" RESET_FG " " cpu_start "%6s" RESET_UL " " pcolor "%-52s" RESET_UL WHITE " %s", $1, $2, $3, $4, "MiB", "%MEM", "%CPU", prog_col, opts_col
        # je complète par des espaces jusqu'au bout de la ligne et puis je passe à la ligne
          printf "\033[K\033[0m\n"

        next
   }
# PROCESSUS ($1=PID  $2=PPID  $3=USER  $4=NICE  $5=RSS  $6=%MEM  $7=%CPU  $8=CMD => $9, $10,... = arguments de la commande)
   {
        # Gestion des lignes et scrolling (data_row est un compteur de ligne qu'on incrémente)
          data_row++
          if(data_row <= offset) next

        # Définition des valeurs à afficher RAM, %MEM, %CPU, PID, PPID,...
          ram=$5/1024
          mem=$6
          cpu=$7
          pid_str=sprintf("%7d",$1)
          ppid_str=sprintf("%7d",$2)
          user_str=sprintf("%-10s",$3)
          nice_str=sprintf("%3s",$4)
          mib_str=sprintf("%6.0f",ram)
          mem_str=sprintf("%6.1f",mem)
          cpu_str=sprintf("%6.1f",cpu/ncpu)
          cmd=$8

        # Détection des processus noyau (entre crochets dans ps)
          is_kernel=(cmd~/^\[/)
        # Si la ligne correspond à un processus noyau et que l'option d'affichage des processus noyau n'est pas sélectionnée, on zappe.
          if (kernel == 0 && is_kernel) next
        # Si la ligne ne correspond pas à un processus noyau et que l'option d'affichage des processus noyau est sélectionnée sur "noyau only", on zappe.
          if (kernel == 2 && !is_kernel) next
        # Si la ligne ne correspond pas à un processus noyau, on prépare des filtres.
          if(!is_kernel){
             if(cmd~"ps" && $9=="-o") next                              # on zappe si ps -o
             if(cmd~"awk" && $9=="-v") next                             # on zappe si awk -v
             if (!showopts) sub(/^.*\//,"",cmd)                         # on supprime le chemin complet pour ne conserver que basename
          }
        # on tronque le champ cmd à 52 caractères fixes, alignés à gauche
          cmd_padded=sprintf("%-52s",cmd)
        # on concatène les arguments de cmd dans 1 seule variable (opts)
          opts=""
          if(NF>8){ for(i=9;i<=NF;i++) opts=opts (i>9?" ":"") $i }
        # on tronque opts pour tenir sur 1 seule ligne donc on calcule la longueur des champs déjà affichés puis on soustrait.
          opts_truncated=""
          if(opts!="" && showopts==1){
            base_len=length(pid_str " " ppid_str " " user_str " " nice_str " " mib_str " " mem_str " " cpu_str "   " cmd_padded " ")
            if(width>base_len) opts_truncated=substr(opts,1,width-base_len)
          }
        # filtre par mot clé sur les champs user, cmd et opts (tronqué)
        search_text=$3 " " cmd
        if(opts!="") search_text=search_text " " opts_truncated
        if(filter != "" && tolower(search_text) !~ tolower(filter)) next

        # Définition des couleurs
          # PID
          pid_col=MAGENTA pid_str " " CYAN ppid_str RESET
          # USER
          if($3=="root")
              user_col=RED user_str RESET
          else if ($3==me)
              user_col=BLUE user_str RESET
          else
              user_col=WHITE user_str RESET
          # NICE
          if($4=="-")
              nice_col=GREY nice_str RESET
          else if($4<0)
              nice_col=YELLOW nice_str RESET
          else
              nice_col=CYAN nice_str RESET
          # MIB
          mib_col=GREEN mib_str " " mem_str " " cpu_str RESET
          # CMD
            if(is_kernel){
                cmd_col=CYAN cmd_padded RESET
            } else {
                slash = match(cmd, /\/[^\/]*$/)
                if(showopts==1 && slash){
                    dir_part = substr(cmd, 1, RSTART)
                    base_part = substr(cmd, RSTART+1)
                    cmd_col = GREY dir_part RESET YELLOW base_part RESET
                    # PAD fixe pour 52 cols VISIBLES (compense ANSI)
                    cmd_col = cmd_col sprintf("%-*s", 52-length(base_part)-length(dir_part), " ")
                } else {
                    cmd_col = YELLOW cmd_padded RESET
                }
            }


        # Définition et affichage de la ligne complète en couleur
          line_color=pid_col " " user_col " " nice_col " " mib_col "   " cmd_col
          if(opts_truncated!="") line_color=line_color " " GREY opts_truncated RESET
          print line_color EL  # EL pour remplir d'espace vide jusqu'au bout de la ligne
          fflush()             # vide buffer awk

        # Calculs pour le FOOTER
          total_ram+=ram
          total_cpu+=cpu
          total_mem+=mem
          count++
          displayed++

        # Sortie si on a affiché le max de ligne possible
          if(limit>0&&displayed==limit) exit
    }
# FOOTER
    END{
        if(nofooter) exit
        printf RED "%2s %2s %-20s %3s %6.0f %6.1f %6.1f %5s %s\033[K\n" RESET, "" , "" , "TOTAL (displayed):" , "" , total_ram , total_mem , total_cpu/ncpu , " ("count, "proc out of " totalproc ")"
        print displayed > drawn_file
        close(drawn_file)
    }
EOF
)
