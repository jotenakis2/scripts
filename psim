#####################################################################################################################################
MANAGE-ARGS(){
    local opts
    local limit_arg=""
    local args=()

    # argument en --X 'mode statique X ligne affichée'
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --[0-9]*)
                limit_arg=$1
                shift
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done

    # autres arguments longs ou courts
    if ! opts=$(getopt \
        -o ckpPmnuHFKOw:hvC0g: \
        -l cpu,pid,ppid,mem,user,cmd,fullcmd,newbie,kernel,no-header,no-footer,no-color,watch:,kernel-only,help,version,filter: \
        -n "${NAME}" -- "${args[@]}" 2>&1); then
        echo ""
        echo -e "${Rouge}Erreur${Reset} : option inconnue ou invalide." >&2
        echo ""
        USAGE
        exit 1
    fi
    eval set -- "${opts}"

    local k=0 konly=0

    while true; do
        case "$1" in
            -p|--pid)         SORT="pid"                  ; shift   ;;
            -P|--ppid)        SORT="ppid"                 ; shift   ;;
            -c|--cpu)         SORT="-%cpu"                ; shift   ;;
            -m|--mem)         SORT="-rss"                 ; shift   ;;
            -u|--user)        SORT="user"                 ; shift   ;;
            -C|--cmd)         SORT="cmd"                  ; shift   ;;
            -0|--no-color)    NO_COLOR=1 && DEFINE_COLORS ; shift   ;;
            -n|--newbie)      NEWBIE=1                    ; shift   ;;
            -k|--kernel)      k=1                         ; shift   ;;
            -K|--kernel-only) konly=1                     ; shift   ;;
            -H|--no-header)   NO_HEADER=1                 ; shift   ;;
            -F|--no-footer)   TIPS_STATE=0                ; shift   ;;
            -O|--fullcmd)     SHOW_OPTS=1                 ; shift   ;;
            -g|--filter)      FILTER="$2"                 ; shift 2 ;;
            -h|--help)        HELP    ;;
            -v|--version)     VERSION ; exit 0;;
            --)               shift   ; break ;;
            -w|--watch)
                if [[ $2 =~ ^[0-9]+$ ]]; then
                    INTERVAL=$2 ; shift 2
                    [[ ${INTERVAL} -ge ${SEUILFREEZE} ]] && FREEZE=1 # au moins 1h on considère FREEZE
                    [[ ${INTERVAL} -eq 0 ]] && STATIC=1
                else
                    echo -e "${Rouge}Erreur${Reset} : l'option ${Bleu}-w/--watch${Reset} attend un entier >= 0." >&2
                    exit 1
                fi
                ;;
            *)
                echo -e "${Rouge}Erreur${Reset} : Argument inattendu (bug interne) : ${Bleu}${1}${Reset}."
                usage ; exit 1
                ;;
        esac
    done

# gestion des incompatibilités
    # quand on force le nb de processus à afficher (--XX) on passe en mode statique obligatoirement
    if [[ -n ${limit_arg} ]]; then
        LIMIT="${limit_arg#--}"
        STATIC=1
    fi

    # processus noyau
    if [[ ${konly} -eq 1 && ${k} -eq 1 ]]; then
        echo -e "\n${Rouge}NOTE\n${Reset}   Les options ${Bleu}--kernel${Reset} et ${Bleu}--kernel-only${Reset} sont incompatibles !" >&2
        echo "" ; usage ; exit 1
    fi
    [[ ${konly} -eq 1 ]] && KERNEL=2
    [[ ${k}     -eq 1 ]] && KERNEL=1

    # force mode affichage fullcmd si tri par cmd et si FILTRE non vide
    [[ "${SORT}" = "cmd" ]] && SHOW_OPTS=1
    [[ -n "${FILTER}" ]] && SHOW_OPTS=1

    # force pas d'affichage KERNEL en mode filtrage
    [[ -n "${FILTER}" ]] && KERNEL=0

# stdout est envoyé dans un fichier => force static
    if [[ ! -t 1 ]]; then
        NO_COLOR=1 ; NO_HEADER=1 ; TIPS_STATE=0 ; INTERVAL=0 ; STATIC=1
    fi

# on stocke les variables utilisées au lancement
    INTERVALDEF=${INTERVAL}
    LOG
    return 0
}
#####################################################################################################################################
STATS() {
	local file1 file2 file3 file4 file5 allproc userlandproc kernelproc displayedtop=6 top=50 HEAD
	SORT=pid ; LIMIT=0 ; STATIC=1 ; NEWBIE=0 ; OFFSET=0 ; NO_COLOR=1 ; FORCE_HEADER=1 ; SHOW_OPTS=1
	FILTER=""
	readonly file1="${DIRCACHE}/all"
	readonly file2="${DIRCACHE}/userland"
	readonly file3="${DIRCACHE}/kernel"
	readonly file4="${DIRCACHE}/top${top}cpu"
	readonly file5="${DIRCACHE}/top${top}mem"

	KERNEL=1 ; DISPLAY_STATIC > "${file1}"
	KERNEL=0 ; DISPLAY_STATIC > "${file2}"
	KERNEL=2 ; DISPLAY_STATIC > "${file3}"
	allproc=$(wc -l < "${file1}")      && ((allproc--))           # header à ne pas compter
	userlandproc=$(wc -l < "${file2}") && ((userlandproc--))      # header à ne pas compter
	kernelproc=$(wc -l < "${file3}")   && ((kernelproc--))        # header à ne pas compter

	echo -e "${Jaune}Statistiques processus${Reset}"
	printf "=> Utilisateurs : ${Vert}%4d\e[0m (${Bleu}%s${Reset})\n" "${userlandproc}" "${file2}"
	printf "=> Noyau        : ${Vert}%4d\e[0m (${Bleu}%s${Reset})\n" "${kernelproc}"   "${file3}"
	printf "=> Total        : ${Vert}%4d\e[0m (${Bleu}%s${Reset})\n" "${allproc}"      "${file1}"
    echo ""

	LIMIT=${top}
	HEAD=$((displayedtop + 1))
	NEWBIE=1 ; KERNEL=0 ; SHOW_OPTS=0 ;
    SORT=-%cpu ; DISPLAY_STATIC > "${file4}"
    SORT=-rss  ; DISPLAY_STATIC > "${file5}"
    echo -e "${Jaune}Top par %CPU${Reset} (${Bleu}${file4}${Reset})${Vert}"
    head -"${HEAD}" "${file4}"
    echo -e "${Reset}  ...\n"
    echo -e "${Jaune}Top par %MEM${Reset} (${Bleu}${file5}${Reset})${Vert}"
    head -"${HEAD}" "${file5}"
    echo -e "${Reset}  ...\n"
	return 0
}
#####################################################################################################################################
DISPLAY_DYNAMIC() {
    local formatps
    WIDTH=${COLUMNS:-$(tput cols)} # tput en fallback
    HEIGHT=${LINES:-$(tput lines)} # tput en fallback
    local NEED_TOTAL=$((OFFSET > 0 || TIPS_STATE >= 1 ? 1 : 0))
    [[ ${NEED_TOTAL} -eq 1 ]] && COUNT_PROCS
    APPLY_TIPS_STATE

    # calcul de la hauteur dynamique
    LIMIT=${HEIGHT}
    [[ ${NO_HEADER}  -eq 0 ]] && LIMIT=$((LIMIT - 1))
    [[ ${NO_FOOTER}  -eq 0 ]] && LIMIT=$((LIMIT - 1))
    [[ ${TIPS_STATE} -ge 1 ]] && LIMIT=$((LIMIT - 1))
    [[ ${LIMIT} -lt 1 ]] && LIMIT=10 # fallback
    #-----------

    # Borne haute de l'offset recalculée après LIMIT connu
    local max_offset=$(( TOTAL_PROCS - LIMIT ))
    [[ ${max_offset} -lt 0 ]] && max_offset=0
    [[ ${OFFSET} -gt ${max_offset} ]] && OFFSET=${max_offset}
    #-----------

    # Gestion dynamique de l'affichage
    local SEUILNOOB=110
    local SEUILKO=100
    [[ ${WIDTH} -le ${SEUILNOOB} ]] && NEWBIE=1
    [[ ${WIDTH} -le ${SEUILKO} ]]   && ERROR
    #-----------

    # on définit le format de ps vs mode enclenché
    [[ ${NEWBIE} -eq 1 ]] && formatps="${PSNOOB}" || formatps="${PSSIMPLE}"

    # on affiche
    if [[ ${TIPS_STATE} -eq 0 ]]; then
        _psawk "${formatps}" | head -c -1 # workaround bug affichage en l'absence du TIPS
    else
        _psawk "${formatps}"
    fi
    # ----------
    return 0
}

#####################################################################################################################################
DISPLAY_STATIC() {
    local formatps
    # en mode statique, pas de calcul automaque de la hauteur, pas de footer/header/tips,
    # et largeur du terminal reste utilisée.
    WIDTH=${COLUMNS:-$(tput cols)}
    [[ "${FORCE_HEADER}" -eq 1 ]] && NO_HEADER=0 || NO_HEADER=1
    NO_FOOTER=1
    TIPS_STATE=0
    COUNT_PROCS
    [[ ${NEWBIE} -eq 1 ]] && formatps="${PSNOOB}" || formatps="${PSSIMPLE}"
    _psawk "${formatps}"
    return 0
}
