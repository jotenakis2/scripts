#####################################################################################################################################
MANAGE-KEYS(){ # gestion des raccourcis en mode dynamique
    local key seq
    # timeout fixé à la valeur de refresh, si pas de touche on sort sans rien faire.
    if read -rt "${INTERVAL}" -n 1 key 2>/dev/null; then
        # Capture séquence ESC (flèches = ESC [A ou ESC [B donc on capture ESC puis 2 caractères)
        if [[ "${key}" == $'\e' ]]; then # ( nota : $'\e' = ESC )
            read -rt 0.05 -n 2 seq 2>/dev/null || true
            key+=${seq}
        fi
        case "${key}" in
            # ------------------------------------- touches simples ------------------------------------- :
            o) [[ -z "${FILTER}" ]] && SHOW_OPTS=$((1 - SHOW_OPTS)) ;; # options
            k) KERNEL=$(( (KERNEL + 1) % 3 )) ; [[ -n "${FILTER}" ]] && KERNEL=0 ;; # process noyau
            h) NO_HEADER=$((1 - NO_HEADER)) ;; # header
            f) TIPS_STATE=$(( (TIPS_STATE + 1) % 3 )) ;; # footer
            q|Q) CLEANUP ;; # sortie

            # gestion délai avant refresh +/-/Freeze
            +) ((INTERVAL < 120)) && ((INTERVAL++)) || true
               ((INTERVAL >= SEUILFREEZE - 1 )) && INTERVAL=$(( INTERVALDEF + 1 )) || true
               ;;

            -) ((INTERVAL > 1)) && ((INTERVAL--)) || true
               ((INTERVAL >= SEUILFREEZE - 1 )) && INTERVAL=$(( INTERVALDEF - 1 )) || true
               ;;

            F)  if [[ "${FREEZE}" -eq 1 ]]; then # on repasse en non gelé avec intervalle par défaut
					FREEZE=0
					INTERVAL=${INTERVALDEF}
				else
            		INTERVAL=${SEUILFREEZE}
            		FREEZE=1
            	fi
            	;;

            # Les différents tris de ps (cpu, mem, cmd, ...)
            c)  if [[ "${SORT}" = "-%cpu" ]]; then
                    SORT="%cpu"
                elif [[ "${SORT}" = "%cpu" ]]; then
                    SORT="-%cpu"
                else
                    SORT="-%cpu"
                fi
                OFFSET=0
                ;;

            C)  if [[ "${SORT}" = "-cmd" ]]; then
                    SORT="cmd"
                elif [[ "${SORT}" = "cmd" ]]; then
                    SORT="-cmd"
                else
                    SORT="cmd"
                fi
                SHOW_OPTS=1 # force affichage chemin complet
                OFFSET=0
                ;;

            u)  if [[ "${SORT}" = "-user" ]]; then
                    SORT="user"
                elif [[ "${SORT}" = "user" ]]; then
                    SORT="-user"
                else
                    SORT="user"
                fi
                OFFSET=0
                ;;

            p)  if [[ "${SORT}" = "-pid" ]]; then
                    SORT="pid"
                elif [[ "${SORT}" = "pid" ]]; then
                    SORT="-pid"
                else
                    SORT="pid"
                fi
                OFFSET=0
                ;;

            P)  if [[ "${SORT}" = "-ppid" ]]; then
                    SORT="ppid"
                elif [[ "${SORT}" = "ppid" ]]; then
                    SORT="-ppid"
                else
                    SORT="ppid"
                fi
                OFFSET=0
                ;;

            m)  if [[ "${SORT}" = "-rss" ]]; then
                    SORT="rss"
                elif [[ "${SORT}" = "rss" ]]; then
                    SORT="-rss"
                else
                    SORT="-rss"
                fi
                OFFSET=0
                ;;

            # ------------------------------------ /touches simples ---

            # ------------------------------------ touches composées  ------------------------------------- :
            $'\e[D') NEWBIE=1 ;; # flèche gauche
            $'\e[C') NEWBIE=0 ;; # flèche droite
            $'\e[A') # flèche haut
                     ((OFFSET > 0)) && ((OFFSET--)) || true
                     COUNT_PROCS
                     ;;

            $'\e[B') # flèche bas
                     local max_offset=$(( TOTAL_PROCS - LIMIT ))
                     [[ ${max_offset} -lt 0 ]] && max_offset=0
                     ((OFFSET < max_offset)) && ((OFFSET++)) || true
                     COUNT_PROCS
                     ;;

            $'\e[H') # Home/Début
                     OFFSET=0
                     COUNT_PROCS
                     ;;

            $'\e[F') # End/Fin
                     max_offset=$(( TOTAL_PROCS - LIMIT ))
                     (( max_offset < 0 )) && max_offset=0
                     OFFSET="${max_offset}"
                     COUNT_PROCS
                     ;;
                # ------------------------------------ /touches composées  ---
            *) ;;
        esac
    fi
    return 0
}
