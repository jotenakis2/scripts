#!/usr/bin/env bash
######################################################################################################################################
# script pour mettre en forme la commande ps pour une meilleure lisibilité.
# 2 dépendances : ps et awk (gnu awk)
# LICENCE GPLv3
# AUTHOR jotenakis
# TODO : récup pid ligne courante pour kill ou renice ?
######################################################################################################################################
set -euo pipefail
readonly VER=0.998                                      # numéro de version du script
readonly NAME="${0##*/}"                                # nom du script
readonly MYPID="$$"                                     # pid du script, pour filtrer lui et les descendants.
readonly DIR="${HOME}/.config/psim"                     # dossier de conf
readonly CONFIG="${DIR}/default.conf"                   # fichier de conf pour écraser les valeurs hardcodées

#---------------------------------------------------------------------------------
MAIN(){
    local blanks displayed_real
    START_TIME=${SECONDS}
	INITIALCONF
	DEFINE_COLORS
	MANAGE-ARGS "$@"
    if [[ "${STATIC}" -eq 1 ]]; then
        DISPLAY_STATIC
    else
        trap CLEANUP INT TERM
        printf '\033[?25l\033[?1049h\033[H'
        while true; do
            # on position le curseur en haut à gauche pour écraser affichage précédent (pas de clear pour éviter effet "flash")
            printf '\033[H'
            # on affiche les processus
            DISPLAY_DYNAMIC
            # si filtrage on ajoute les lignes vides requises
            if [[ -n "${FILTER}" ]]; then
                # on récupère le nb de lignes affichées par awk
                displayed_real=0
                [[ -s "${DRAWN_FILE}" ]] && read -r displayed_real < "${DRAWN_FILE}"
                # on ajoute des lignes blanches pour aller jusqu'en bas du terminal
                blanks=$(( LIMIT - displayed_real ))
                [[ ${blanks} -lt 0 ]] && blanks=0
                for ((i=0; i<blanks; i++)); do
                    printf '\033[K\n'
                done
                # si pas de bandeau je rajoute une ligne vide
                [[ ${TIPS_STATE} -eq 0 ]] && printf '\033[K'
            fi
            # on affiche le bandeau tout en bas si demandé
            [[ "${TIPS_STATE}" -ge 1 ]] && DISPLAY-TIPS
            # on gère les raccourcis clavier
            MANAGE-KEYS
        done
    fi
    exit 0
}
